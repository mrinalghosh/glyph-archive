{
  "name": "glyph-archive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A terminal-styled web app for curating a personal collection of interesting UTF-8 characters.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:misc-technical": "node scripts/gen-glyphs.mjs --range 2300-23FF --export MISC_TECHNICAL --out src/data/blocks/miscTechnical.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
