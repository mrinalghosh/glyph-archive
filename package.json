{
  "name": "glyph-archive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A terminal-styled web app for curating a personal collection of interesting UTF-8 characters.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:misc-technical": "node scripts/gen-glyphs.mjs --range 2300-23FF --export MISC_TECHNICAL --out src/data/blocks/miscTechnical.ts",
    "gen:box-drawing": "node scripts/gen-glyphs.mjs --range 2500-257F --export BOX_DRAWING --out src/data/blocks/boxDrawing.ts",
    "gen:block-elements": "node scripts/gen-glyphs.mjs --range 2580-259F --export BLOCK_ELEMENTS --out src/data/blocks/blockElements.ts",
    "gen:geometric-shapes": "node scripts/gen-glyphs.mjs --range 25A0-25FF --export GEOMETRIC_SHAPES --out src/data/blocks/geometricShapes.ts",
    "gen:misc-symbols": "node scripts/gen-glyphs.mjs --range 2600-26FF --export MISC_SYMBOLS --out src/data/blocks/miscSymbols.ts",
    "gen:dingbats": "node scripts/gen-glyphs.mjs --range 2700-27BF --export DINGBATS --out src/data/blocks/dingbats.ts",
    "gen:misc-symbols-arrows": "node scripts/gen-glyphs.mjs --range 2B00-2BFF --export MISC_SYMBOLS_AND_ARROWS --out src/data/blocks/miscSymbolsAndArrows.ts",
    "gen:letterlike-symbols": "node scripts/gen-glyphs.mjs --range 2100-214F --export LETTERLIKE_SYMBOLS --out src/data/blocks/letterlikeSymbols.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
